# Social Engineering Detection System - API Configuration Template
# Copy this file to .env and fill in your API keys
# .env files are gitignored and will not be committed

# VirusTotal API (https://virustotal.com - 500 requests/day free)
VIRUSTOTAL_API_KEY=

# AbuseIPDB API (https://abuseipdb.com - 1000 requests/day free)
ABUSEIPDB_API_KEY=

# Google Safe Browsing API (https://console.cloud.google.com - 10000 requests/day free)
GOOGLE_SAFEBROWSING_API_KEY=

# Master toggle (optional - auto-enables if any key is present)
# SOCENG_API_ENABLED=true
